
####################################################################
# Slack
####################################################################
WEB_HOOK_URL='https://hooks.slack.com/services/...'
CHANNEL='#channel-name'
ENABLE_SLACK_NOTIFICATION=false
LOG_PATH='/var/log/nginx/detrudr-stream.log'


# must use this in prod
AUDIT_LOG_PATH='/var/log/detrudr/audit.log' 

# local development
# AUDIT_LOG_PATH='/tmp/detrudr-audit.log' 

####################################################################
# Auth
####################################################################
EMAIL='sample-mail@email.com'
PASSWORD='your-password'

####################################################################
# IP Blocking
# Set `DRY_RUN=true` for local/dev environments without iptables permissions.
# Set `DRY_RUN=false` in production where the process has `CAP_NET_ADMIN`.
####################################################################
DRY_RUN=true
